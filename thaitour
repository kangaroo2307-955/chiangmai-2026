<!DOCTYPE html>
<html lang="zh-TW" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>清邁五日遊 Chiang Mai Tour</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        cream: {
                            50: '#FDFBF7',
                            100: '#F7F3E9',
                            200: '#EFE6D5',
                            800: '#5C5243',
                        },
                        lanna: {
                            green: '#2D4A3E',  // 泰北深墨綠
                            sage: '#8A9A86',   // 鼠尾草綠
                            gold: '#D4A359',   // 蘭納暖金
                            clay: '#C86D51',   // 泰北紅陶
                            bg: '#F9F7F2'      // 奶油白底
                        }
                    },
                    fontFamily: {
                        sans: ['Outfit', 'Noto Sans TC', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts & FontAwesome Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Outfit', 'Noto Sans TC', sans-serif;
            background-color: #F9F7F2;
            color: #2D4A3E;
            -webkit-tap-highlight-color: transparent;
        }

        /* 老人模式 / 大字模式 */
        body.senior-mode { font-size: 1.25rem !important; }
        body.senior-mode h1 { font-size: 2.25rem !important; }
        body.senior-mode h2 { font-size: 1.85rem !important; }
        body.senior-mode h3 { font-size: 1.5rem !important; }
        body.senior-mode p, body.senior-mode span, body.senior-mode li, body.senior-mode button { 
            font-size: 1.2rem !important; 
            line-height: 1.6 !important;
        }

        .hide-privacy { filter: blur(5px); user-select: none; }
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-thumb { background: #8A9A86; border-radius: 4px; }
    </style>
</head>
<body class="h-full flex flex-col pb-20 select-none">

    <!-- 頂部 Header (包含全域「回到目錄」按鈕) -->
    <header class="sticky top-0 z-40 bg-lanna-green text-cream-50 px-4 py-3 shadow-md flex justify-between items-center">
        <div class="flex items-center gap-2">
            <button onclick="switchTab('home')" class="p-2 rounded-xl bg-lanna-gold text-lanna-green hover:brightness-110 font-bold transition flex items-center gap-1.5 text-xs shadow">
                <i class="fa-solid fa-house text-sm"></i> 目錄
            </button>
            <div>
                <h1 class="text-base font-bold tracking-wide">清邁五日遊 🐘</h1>
                <p class="text-[10px] text-cream-200">2026/07/27 - 07/31</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <!-- 個資隱私開關 -->
            <button onclick="togglePrivacy()" id="privacyBtn" class="p-2 rounded-full bg-cream-800/40 text-cream-100 hover:bg-lanna-gold hover:text-lanna-green transition" title="隱私模糊">
                <i class="fa-solid fa-eye-slash"></i>
            </button>
            <!-- 大字模式開關 -->
            <button onclick="toggleSeniorMode()" class="px-2.5 py-1 rounded-full text-xs font-bold bg-lanna-gold text-lanna-green shadow hover:brightness-110 transition">
                <i class="fa-solid fa-text-height mr-1"></i>大字
            </button>
        </div>
    </header>

    <!-- 主內容區域 (Tab 轉換) -->
    <main class="flex-1 overflow-y-auto px-4 py-4 max-w-md mx-auto w-full">

        <!-- ================= 0. HOME (主畫面九宮格目錄) ================= -->
        <section id="tab-home" class="tab-content space-y-5">
            
            <!-- 可愛 Banner 卡片與可愛泰國象插圖 -->
            <div class="bg-gradient-to-r from-lanna-green to-lanna-sage text-white rounded-3xl p-5 shadow-lg relative overflow-hidden">
                <div class="relative z-10 space-y-1">
                    <span class="bg-lanna-gold/30 text-lanna-gold text-[10px] font-bold px-2.5 py-0.5 rounded-full border border-lanna-gold/40">Sawasdee Chiang Mai! 🇹🇭</span>
                    <h2 class="text-xl font-bold">清邁精彩之旅目錄</h2>
                    <p class="text-xs text-cream-100/90">請點擊下方功能按鈕開始探索行程：</p>
                </div>
                <!-- 手繪風格大象插圖 -->
                <svg class="absolute -right-3 -bottom-3 w-32 h-32 opacity-20" viewBox="0 0 200 200" fill="currentColor">
                    <path d="M 100,60 C 70,60 50,80 50,110 C 50,130 60,150 70,160 L 70,190 C 70,195 75,200 80,200 L 90,200 C 95,200 100,195 100,190 L 100,170 L 110,170 L 110,190 C 110,195 115,200 120,200 L 130,200 C 135,200 140,195 140,190 L 140,155 C 150,145 160,130 160,110 C 160,80 130,60 100,60 Z M 80,100 C 85,100 90,105 90,110 C 90,115 85,120 80,120 C 75,120 70,115 70,110 C 70,105 75,100 80,100 Z"/>
                </svg>
            </div>

            <!-- 主畫面選單按鈕區 -->
            <div class="grid grid-cols-2 gap-3">
                
                <button onclick="switchTab('shuttle')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-orange-100 text-orange-600 flex items-center justify-center text-lg font-bold">🚗</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">機場接送</div>
                        <div class="text-[10px] text-gray-400">接送時間與地點</div>
                    </div>
                </button>

                <button onclick="switchTab('flight')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-sky-100 text-sky-600 flex items-center justify-center text-lg font-bold">🛫</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">航班資訊</div>
                        <div class="text-[10px] text-gray-400">中華航空 CI851/852</div>
                    </div>
                </button>

                <button onclick="switchTab('hotel')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center text-lg font-bold">🏨</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">飯店住宿</div>
                        <div class="text-[10px] text-gray-400">阿基拉塔佩 / 那皮亞丁</div>
                    </div>
                </button>

                <button onclick="switchTab('plan')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center text-lg font-bold">📅</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">每日行程</div>
                        <div class="text-[10px] text-gray-400">Day 1 - Day 5 細節</div>
                    </div>
                </button>

                <button onclick="switchTab('notice')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-red-100 text-red-600 flex items-center justify-center text-lg font-bold">🚨</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">注意事項</div>
                        <div class="text-[10px] text-gray-400">緊急電話與安全須知</div>
                    </div>
                </button>

                <button onclick="switchTab('lists')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center text-lg font-bold">✅</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">行前清單</div>
                        <div class="text-[10px] text-gray-400">護照、網卡、藥品檢查</div>
                    </div>
                </button>

                <button onclick="switchTab('info')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-rose-100 text-rose-600 flex items-center justify-center text-lg font-bold">☕</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">願望探店</div>
                        <div class="text-[10px] text-gray-400">米其林與咖啡廳</div>
                    </div>
                </button>

                <button onclick="switchTab('souvenir')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-teal-100 text-teal-600 flex items-center justify-center text-lg font-bold">🛍️</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">伴手禮</div>
                        <div class="text-[10px] text-gray-400">Big C 超市採購清單</div>
                    </div>
                </button>

                <button onclick="switchTab('rate')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-yellow-100 text-yellow-600 flex items-center justify-center text-lg font-bold">💱</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">外幣計算</div>
                        <div class="text-[10px] text-gray-400">銀即時現鈔賣出價換算</div>
                    </div>
                </button>

                <button onclick="switchTab('wallet')" class="bg-white p-3.5 rounded-2xl border border-cream-200 shadow-sm flex items-center gap-3 hover:bg-cream-50 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center text-lg font-bold">💰</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">記帳功能</div>
                        <div class="text-[10px] text-gray-400">記帳明細與拍照存證</div>
                    </div>
                </button>

                <button onclick="switchTab('translate')" class="col-span-2 bg-gradient-to-r from-lanna-gold/20 to-lanna-clay/20 p-4 rounded-2xl border border-lanna-gold/40 shadow-sm flex items-center gap-3 hover:bg-cream-100 transition text-left">
                    <div class="w-10 h-10 rounded-xl bg-lanna-gold text-lanna-green flex items-center justify-center text-lg font-bold">🗣️</div>
                    <div>
                        <div class="font-bold text-sm text-lanna-green">泰文即時翻譯對照卡</div>
                        <div class="text-[10px] text-gray-600">日常問候、點餐少冰不辣、問路與溝通句型</div>
                    </div>
                </button>

            </div>
        </section>

        <!-- ================= 1. SHUTTLE (搭乘機場接送) ================= -->
        <section id="tab-shuttle" class="tab-content space-y-4 hidden">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg text-lanna-green flex items-center gap-2">
                    <span>🚗</span> 機場接送資訊
                </h2>
                <button onclick="switchTab('home')" class="text-xs text-lanna-clay font-bold">← 返回主畫面</button>
            </div>

            <div class="bg-white p-4 rounded-2xl border border-cream-200 shadow-sm space-y-3">
                <div class="bg-cream-50 p-3 rounded-xl border border-cream-200 space-y-1">
                    <span class="font-bold text-lanna-clay block text-sm">[去程接送] 2026/07/27 (一)</span>
                    <p class="text-xs">📍 第一站：新竹 (04:00 出發) - 5人 ($1,900)</p>
                    <p class="text-xs">📍 第二站：林口 (04:30 出發) - 1人 ($600)</p>
                    <p class="text-[11px] text-gray-500 mt-1">預計 05:10 前抵達桃園國際機場第一航廈。</p>
                </div>

                <div class="bg-cream-50 p-3 rounded-xl border border-cream-200 space-y-1">
                    <span class="font-bold text-lanna-clay block text-sm">[回程接送] 2026/07/31 (五)</span>
                    <p class="text-xs">📍 新竹 - 5人 ($1,900)</p>
                    <p class="text-[11px] text-gray-500 mt-1">💡 註：請於桃機辦理入境拿到行李後，自行聯絡包車司機指定車頭會合。</p>
                </div>
            </div>
        </section>

        <!-- ================= 2. FLIGHT (航班資訊) ================= -->
        <section id="tab-flight" class="tab-content space-y-4 hidden">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg text-lanna-green flex items-center gap-2">
                    <span>🛫</span> 航班詳細資訊
                </h2>
                <button onclick="switchTab('home')" class="text-xs text-lanna-clay font-bold">← 返回主畫面</button>
            </div>

            <div class="bg-white p-4 rounded-2xl border border-cream-200 shadow-sm space-y-3 text-xs">
                <div class="border-b border-cream-200 pb-2">
                    <span class="font-bold text-lanna-green text-sm block">中華航空 China Airlines</span>
                </div>
                
                <div class="space-y-1 bg-cream-50 p-3 rounded-xl">
                    <span class="font-bold text-lanna-green block">🛫 去程：CI851</span>
                    <p>07:30 桃園國際機場 (TPE) ➔ 10:20 清邁國際機場 (CNX)</p>
                </div>

                <div class="space-y-1 bg-cream-50 p-3 rounded-xl">
                    <span class="font-bold text-lanna-green block">🛬 回程：CI852</span>
                    <p>11:20 清邁國際機場 (CNX) ➔ 16:00 桃園國際機場 (TPE)</p>
                </div>

                <div class="bg-lanna-gold/10 p-3 rounded-xl text-lanna-green space-y-1 border border-lanna-gold/30">
                    <p>💰 經濟來回：$18,204 /人</p>
                    <p>💰 經去商回：$22,948 /人</p>
                    <p>🛡️ 保險：$1,676 | 📶 網卡：$185</p>
                </div>
            </div>
        </section>

        <!-- ================= 3. HOTEL (飯店資訊) ================= -->
        <section id="tab-hotel" class="tab-content space-y-4 hidden">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg text-lanna-green flex items-center gap-2">
                    <span>🏨</span> 住宿飯店資訊
                </h2>
                <button onclick="switchTab('home')" class="text-xs text-lanna-clay font-bold">← 返回主畫面</button>
            </div>

            <div class="bg-white rounded-2xl p-4 shadow-sm border border-cream-200 space-y-2">
                <div class="flex justify-between items-start">
                    <h3 class="font-bold text-lanna-green">1. 阿基拉塔佩飯店</h3>
                    <span class="text-xs bg-lanna-gold/20 text-lanna-green px-2 py-0.5 rounded font-bold">07/27-07/29</span>
                </div>
                <p class="text-xs text-gray-500">Akira Thaphae Hotel / โรงแรมอาคิรา ท่าแพ</p>
                <p class="text-xs">📍 <span class="privacy-text">Thaphae, Chang Moi, Chiang Mai</span></p>
                <p class="text-xs">🍳 早餐：週一至五 07:00-10:00 (假日關閉)</p>
                <p class="text-xs text-lanna-clay font-bold">⚠️ 嚴禁攜帶榴槤、山竹入住</p>
                <a href="https://maps.app.goo.gl/n1uugu3ECD6roM3G7?g_st=ic" target="_blank" class="mt-2 inline-block text-xs bg-lanna-green text-white px-3 py-1.5 rounded-lg">
                    <i class="fa-solid fa-map-location-dot"></i> 開啟地圖
                </a>
            </div>

            <div class="bg-white rounded-2xl p-4 shadow-sm border border-cream-200 space-y-2">
                <div class="flex justify-between items-start">
                    <h3 class="font-bold text-lanna-green">2. 那皮亞丁精品飯店</h3>
                    <span class="text-xs bg-lanna-gold/20 text-lanna-green px-2 py-0.5 rounded font-bold">07/29-07/31</span>
                </div>
                <p class="text-xs text-gray-500">Nampiangdin Boutique Hotel / น้ำเพียงดิน บูติค โฮเทล</p>
                <p class="text-xs">📍 <span class="privacy-text">14/3 Nantaram 5 Kor Alley, Haiya</span></p>
                <p class="text-xs">🍳 早餐：每日 07:00-10:00</p>
                <p class="text-xs">💰 費用：$5,400 (4晚/人總價)</p>
                <a href="https://maps.app.goo.gl/EZeeKqaLUmzax9vF7?g_st=ic" target="_blank" class="mt-2 inline-block text-xs bg-lanna-green text-white px-3 py-1.5 rounded-lg">
                    <i class="fa-solid fa-map-location-dot"></i> 開啟地圖
                </a>
            </div>
        </section>

        <!-- ================= 4. PLAN (每日行程) ================= -->
        <section id="tab-plan" class="tab-content space-y-4 hidden">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg text-lanna-green flex items-center gap-2">
                    <span>📅</span> 每日行程安排
                </h2>
                <button onclick="switchTab('home')" class="text-xs text-lanna-clay font-bold">← 返回主畫面</button>
            </div>

            <div class="flex gap-1 overflow-x-auto pb-1" id="day-tabs">
                <button onclick="switchDay(1)" id="day-tab-1" class="day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-lanna-green text-white">Day 1 (7/27)</button>
                <button onclick="switchDay(2)" id="day-tab-2" class="day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-cream-200 text-lanna-green">Day 2 (7/28)</button>
                <button onclick="switchDay(3)" id="day-tab-3" class="day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-cream-200 text-lanna-green">Day 3 (7/29)</button>
                <button onclick="switchDay(4)" id="day-tab-4" class="day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-cream-200 text-lanna-green">Day 4 (7/30)</button>
                <button onclick="switchDay(5)" id="day-tab-5" class="day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-cream-200 text-lanna-green">Day 5 (7/31)</button>
            </div>

            <div id="itinerary-list" class="space-y-3"></div>
        </section>

        <!-- ================= 5. NOTICE (注意事項) ================= -->
        <section id="tab-notice" class="tab-content space-y-4 hidden">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg text-lanna-green flex items-center gap-2">
                    <span>🚨</span> 安全須知與小叮嚀
                </h2>
                <button onclick="switchTab('home')" class="text-xs text-lanna-clay font-bold">← 返回主畫面</button>
            </div>

            <div class="bg-cream-100/80 rounded-2xl p-4 border border-cream-200 space-y-3 text-xs">
                <h3 class="font-bold text-lanna-green text-sm">📞 緊急聯絡電話</h3>
                <div class="space-y-1.5 bg-white p-3 rounded-xl border border-cream-200">
                    <p>• 泰國觀光警察：<a href="tel:1155" class="text-lanna-clay font-bold underline">1155</a> (具備中文服務)</p>
                    <p>• 救護車/急救電話：<a href="tel:1669" class="text-lanna-clay font-bold underline">1669</a></p>
                    <p>• 駐泰國台北經濟文化辦事處：<a href="tel:+66818258208" class="text-lanna-clay font-bold underline">+66-81-825-8208</a></p>
                </div>

                <h3 class="font-bold text-lanna-green text-sm">💡 泰國旅遊注意事項</h3>
                <div class="bg-white p-3 rounded-xl border border-cream-200 space-y-2">
                    <p>• 💵 <strong>現金抽查：</strong> 入境泰國每人需準備等值 20,000 泰銖現金以備海關抽查。</p>
                    <p>• 🛕 <strong>寺廟禮儀：</strong> 參訪白廟、藍廟等寺廟請勿穿著短褲、無袖背心。</p>
                    <p>• 🚗 <strong>交通安全：</strong> 泰國為右駕國家，跨越馬路請先注意右方來車。</p>
                    <p>• 🏨 <strong>水果禁令：</strong> 多數飯店嚴禁帶榴槤及山竹入住，违者罰款。</p>
                </div>
            </div>
        </section>

        <!-- ================= 6. LISTS (行前清單) ================= -->
        <section id="tab-lists" class="tab-content space-y-4 hidden">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-lg text-lanna-green flex items-center gap-2">
                    <span>✅</span> 行前必備檢查清單
                </h2>
                <button onclick="switchTab('home')" class="text-xs text-lanna-clay font-bold">← 返回主畫面</button>
            </div>

            <div class="bg-white rounded-2xl p-4 shadow-sm border border-cream-200 space-y-3">
                <div id="checklist-container" class="space-y-2 text-sm"></div>
            </div>

            <div class="bg-white rounded-2xl p-4 shadow-sm border border-cream-200 space-y-3">
                <h3 class="font-bold text-lanna-green text-sm flex items-center gap-2">
