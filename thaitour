    <!-- JavaScript 核心程式碼 -->
    <script>
        const APP_DATA_KEY = 'chiangmai_trip_app_v3';
        let currentExchangeRate = 0.985; // 臺灣銀行現鈔賣出價參考匯率

        let appState = {
            seniorMode: false,
            privacyHidden: false,
            currentDay: 1,
            itinerary: {
                1: [
                    { time: '04:00', title: '機場接送 (第一站 - 新竹)', note: '司機抵達', done: false },
                    { time: '04:30', title: '機場接送 (第二站 - 林口)', note: '', done: false },
                    { time: '05:10', title: '抵達桃園機場第一航廈', note: '辦理托運出境', done: false },
                    { time: '07:30', title: '搭乘 CI851 飛往清邁', note: '機上休息', done: false },
                    { time: '10:20', title: '落地清邁機場 (CNX)', note: '辦理入境與取行李', done: false },
                    { time: '12:00', title: '搭 Grab 前往阿基拉塔佩飯店寄放行李', note: '', done: false }
                ],
                2: [
                    { time: '07:30', title: '飯店享用早餐', note: '', done: false },
                    { time: '09:00', title: '參加“清萊一日遊” (白廟/藍廟)', note: '寺廟不可穿著短褲', done: false }
                ],
                3: [
                    { time: '08:00', title: '早餐與辦理退房', note: '換至那皮亞丁精品飯店', done: false },
                    { time: '13:00', title: '大象保護區體驗', note: '請多帶一套替換衣物', done: false }
                ],
                4: [{ time: '08:00', title: '全日自由活動探店購物', note: '前往白色市集或古城區', done: false }],
                5: [{ time: '11:20', title: '搭乘 CI852 飛回台北', note: '預計 16:00 抵達桃園機場', done: false }]
            },
            expenses: [],
            memo: '',
            checklist: [
                { text: '旅遊平安不便險投保', checked: false },
                { text: '護照正本/國際駕照', checked: false },
                { text: '泰銖現金 (建議每人2萬泰銖)', checked: false },
                { text: '常備藥品 (腸胃/暈車)', checked: false }
            ],
            wishlist: [
                { id: 'w1', title: 'Baan Landai Fine Thai Cuisine', category: '探店', note: '米其林推薦餐廳', done: false },
                { id: 'w2', title: 'Big C 超市採購手標茶', category: '伴手禮', note: '泰奶粉、蜂蜜', done: false }
            ]
        };

        let tempBase64Photo = '';

        window.addEventListener('DOMContentLoaded', () => {
            loadLocalData();
            renderItinerary();
            renderExpenses();
            renderChecklist();
            renderWishlist();
            document.getElementById('memo-input').value = appState.memo || '';
            renderMemoDisplay();
        });

        function loadLocalData() {
            const saved = localStorage.getItem(APP_DATA_KEY);
            if (saved) {
                try { appState = Object.assign(appState, JSON.parse(saved)); } catch(e) {}
            }
        }

        function saveData() {
            localStorage.setItem(APP_DATA_KEY, JSON.stringify(appState));
        }

        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById(`tab-${tabName}`).classList.remove('hidden');

            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('text-lanna-green');
                btn.classList.add('text-gray-400');
            });

            const currentNav = document.getElementById(`nav-${tabName}`);
            if (currentNav) {
                currentNav.classList.add('text-lanna-green');
                currentNav.classList.remove('text-gray-400');
            }
        }

        function togglePrivacy() {
            appState.privacyHidden = !appState.privacyHidden;
            document.querySelectorAll('.privacy-text').forEach(el => {
                el.classList.toggle('hide-privacy', appState.privacyHidden);
            });
            saveData();
        }

        function toggleSeniorMode() {
            appState.seniorMode = !appState.seniorMode;
            document.body.classList.toggle('senior-mode', appState.seniorMode);
            saveData();
        }

        function switchDay(day) {
            appState.currentDay = day;
            document.querySelectorAll('.day-btn').forEach((btn, idx) => {
                btn.className = (idx + 1 === day) 
                    ? "day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-lanna-green text-white"
                    : "day-btn px-3 py-1.5 rounded-xl text-xs font-bold bg-cream-200 text-lanna-green";
            });
            renderItinerary();
        }

        function renderItinerary() {
            const container = document.getElementById('itinerary-list');
            container.innerHTML = '';
            const items = appState.itinerary[appState.currentDay] || [];

            items.forEach((item, idx) => {
                const card = document.createElement('div');
                card.className = `bg-white p-3 rounded-xl border border-cream-200 shadow-sm flex items-start gap-3 ${item.done ? 'opacity-50 line-through' : ''}`;
                card.innerHTML = `
                    <input type="checkbox" ${item.done ? 'checked' : ''} onchange="toggleItineraryDone(${idx})" class="mt-1 w-4 h-4 accent-lanna-green">
                    <div class="flex-1 text-xs">
                        <div class="flex justify-between font-bold text-lanna-green">
                            <span>⏱️ ${item.time}</span>
                            <span>${item.title}</span>
                        </div>
                        <div class="mt-1 text-gray-600">${item.note}</div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function toggleItineraryDone(idx) {
            appState.itinerary[appState.currentDay][idx].done = !appState.itinerary[appState.currentDay][idx].done;
            saveData();
            renderItinerary();
        }

        async function fetchLiveExchangeRate() {
            try {
                const res = await fetch('https://open.er-api.com/v6/latest/THB');
                const data = await res.json();
                if (data && data.rates && data.rates.TWD) {
                    currentExchangeRate = data.rates.TWD;
                    document.getElementById('current-rate-display').innerText = currentExchangeRate.toFixed(4);
                    document.getElementById('rate-update-time').innerText = '即時外匯更新成功';
                    convertCurrency('thb');
                }
            } catch(e) {
                alert('外匯更新失敗，使用銀行現鈔賣出參考值 0.985');
            }
        }

        function convertCurrency(type) {
            if (type === 'thb') {
                const thb = document.getElementById('calc-thb').value;
                document.getElementById('calc-twd').value = Math.round(thb * currentExchangeRate);
            } else {
                const twd = document.getElementById('calc-twd').value;
                document.getElementById('calc-thb').value = Math.round(twd / currentExchangeRate);
            }
        }

        function handlePhotoUpload(e) {
            const file = e.target.files[0];
            if (!file) return;
            document.getElementById('photo-preview-name').innerText = file.name;
            const reader = new FileReader();
            reader.onload = function(evt) { tempBase64Photo = evt.target.result; }
            reader.readAsDataURL(file);
        }

        function addExpense() {
            const item = document.getElementById('expense-item').value;
            const amount = parseFloat(document.getElementById('expense-amount').value);
            const payer = document.getElementById('expense-payer').value || '未指定';
            const method = document.getElementById('expense-method').value;

            if (!item || isNaN(amount)) { alert('請填寫完整名稱與金額'); return; }

            appState.expenses.push({ id: Date.now(), item, amount, payer, method, photo: tempBase64Photo });
            tempBase64Photo = '';
            document.getElementById('expense-item').value = '';
            document.getElementById('expense-amount').value = '';
            saveData();
            renderExpenses();
        }

        function renderExpenses() {
            const container = document.getElementById('expense-list');
            container.innerHTML = '';
            let total = 0;

            appState.expenses.forEach(exp => {
                total += exp.amount;
                const card = document.createElement('div');
                card.className = "bg-cream-50 p-2.5 rounded-xl border border-cream-200 text-xs flex justify-between items-center";
                card.innerHTML = `
                    <div class="flex items-center gap-2">
                        ${exp.photo ? `<img src="${exp.photo}" class="w-8 h-8 object-cover rounded-lg">` : ''}
                        <div>
                            <div class="font-bold text-lanna-green">${exp.item}</div>
                            <div class="text-[10px] text-gray-500">${exp.payer} (${exp.method})</div>
                        </div>
                    </div>
                    <div class="font-bold text-lanna-clay">${exp.amount} THB</div>
                `;
                container.appendChild(card);
            });
            document.getElementById('total-expense-thb').innerText = `${total} THB`;
        }

        function renderChecklist() {
            const container = document.getElementById('checklist-container');
            container.innerHTML = '';
            appState.checklist.forEach((item, idx) => {
                const div = document.createElement('div');
                div.className = "flex items-center gap-2 p-1.5 hover:bg-cream-50 rounded-lg";
                div.innerHTML = `
                    <input type="checkbox" ${item.checked ? 'checked' : ''} onchange="toggleChecklist(${idx})" class="accent-lanna-green w-4 h-4">
                    <span class="${item.checked ? 'line-through text-gray-400' : 'text-cream-800'}">${item.text}</span>
                `;
                container.appendChild(div);
            });
        }

        function toggleChecklist(idx) {
            appState.checklist[idx].checked = !appState.checklist[idx].checked;
            saveData();
            renderChecklist();
        }

        function saveMemo() {
            appState.memo = document.getElementById('memo-input').value;
            saveData();
            renderMemoDisplay();
        }

        function renderMemoDisplay() {
            document.getElementById('memo-display').innerText = appState.memo || '尚無紀錄';
        }

        function openAddWishModal() { document.getElementById('wish-modal').classList.remove('hidden'); }
        function closeAddWishModal() { document.getElementById('wish-modal').classList.add('hidden'); }

        function saveWishItem() {
            const title = document.getElementById('wish-title').value;
            const category = document.getElementById('wish-category').value;
            const note = document.getElementById('wish-note').value;
            if (!title) return;

            appState.wishlist.push({ id: 'w_' + Date.now(), title, category, note, done: false });
            closeAddWishModal();
            saveData();
            renderWishlist();
        }

        function renderWishlist() {
            const wishContainer = document.getElementById('wishlist-container');
            const souvenirContainer = document.getElementById('souvenir-container');
            if(wishContainer) wishContainer.innerHTML = '';
            if(souvenirContainer) souvenirContainer.innerHTML = '';

            appState.wishlist.forEach((item, idx) => {
                const card = document.createElement('div');
                card.className = "bg-cream-50 p-3 rounded-xl border border-cream-200 text-xs space-y-1";
                card.innerHTML = `
                    <div class="flex justify-between items-center font-bold text-lanna-green">
                        <span>${item.title}</span>
                        <span class="text-[10px] bg-lanna-gold/20 text-lanna-green px-1.5 py-0.5 rounded">${item.category}</span>
                    </div>
                    <p class="text-gray-600 text-[11px]">${item.note}</p>
                `;
                if (item.category === '伴手禮' && souvenirContainer) souvenirContainer.appendChild(card);
                else if (wishContainer) wishContainer.appendChild(card);
            });
        }
    </script>
</body>
</html>
